{
  "background":            { "$type": "color", "$value": "{color.white}" },
  "foreground":            { "$type": "color", "$value": "{color.neutral.950}" },
  "card":                  { "$type": "color", "$value": "{color.white}" },
  "card-foreground":       { "$type": "color", "$value": "{color.neutral.950}" },
  "popover":               { "$type": "color", "$value": "{color.white}" },
  "popover-foreground":    { "$type": "color", "$value": "{color.neutral.950}" },

  "primary":                    { "$type": "color", "$value": "{brand-primary}", "$description": "Light: primary da marca (âncora brand-primary = shade 700). Simétrico ao mode/dark, que usa brand-primary-on-dark (600)." },
  "primary-foreground":         { "$type": "color", "$value": "{brand-primary-foreground}" },
  "ring":                       { "$type": "color", "$value": "{brand-ring}" },
  "sidebar-primary":            { "$type": "color", "$value": "{brand-primary}" },
  "sidebar-primary-foreground": { "$type": "color", "$value": "{brand-primary-foreground}" },
  "sidebar-ring":               { "$type": "color", "$value": "{brand-ring}" },

  "secondary":             { "$type": "color", "$value": "{brand-secondary}", "$description": "Light: secondary da marca (âncora brand-secondary = roxo CRP shade 700). Espelha o primary; segue a marca (CRP roxo, MarcaB azul)." },
  "secondary-foreground":  { "$type": "color", "$value": "{brand-secondary-foreground}" },
  "muted":                 { "$type": "color", "$value": "{color.neutral.100}" },
  "muted-foreground":      { "$type": "color", "$value": "{color.neutral.600}", "$description": "Texto secundário/muted. neutral.600 (não 500) p/ passar AA 4.5 SOBRE a superfície muted (neutral.100): 500 dava 4.35. Contrato compartilhado → vale p/ CRP e MarcaB no Light." },
  "accent":                { "$type": "color", "$value": "{color.neutral.100}" },
  "accent-foreground":     { "$type": "color", "$value": "{color.neutral.900}" },
  "destructive":           { "$type": "color", "$value": "{color.red.600}" },
  "destructive-foreground":{ "$type": "color", "$value": "{color.neutral.50}" },
  "warning":               { "$type": "color", "$value": "{color.amber.500}" },
  "warning-foreground":    { "$type": "color", "$value": "{color.amber.950}" },
  "success":               { "$type": "color", "$value": "{color.green.700}" },
  "success-foreground":    { "$type": "color", "$value": "{color.white}" },
  "info":                  { "$type": "color", "$value": "{color.sky.700}" },
  "info-foreground":       { "$type": "color", "$value": "{color.white}" },
  "chart-1":                  { "$type": "color", "$value": "{color.blue.500}" },
  "chart-1-solid":            { "$type": "color", "$value": "{color.blue.600}" },
  "chart-1-solid-foreground": { "$type": "color", "$value": "{color.white}" },
  "chart-1-soft":             { "$type": "color", "$value": "{color.blue.100}" },
  "chart-1-soft-foreground":  { "$type": "color", "$value": "{color.blue.800}" },
  "chart-2":                  { "$type": "color", "$value": "{color.violet.500}" },
  "chart-2-solid":            { "$type": "color", "$value": "{color.violet.600}" },
  "chart-2-solid-foreground": { "$type": "color", "$value": "{color.white}" },
  "chart-2-soft":             { "$type": "color", "$value": "{color.violet.100}" },
  "chart-2-soft-foreground":  { "$type": "color", "$value": "{color.violet.800}" },
  "chart-3":                  { "$type": "color", "$value": "{color.green.600}", "$description": "600 (não 500): série gráfica precisa de ≥3:1 vs background/card no light (WCAG 1.4.11) — 500 media 2.25:1. Validado em check.mjs." },
  "chart-3-solid":            { "$type": "color", "$value": "{color.green.700}" },
  "chart-3-solid-foreground": { "$type": "color", "$value": "{color.white}" },
  "chart-3-soft":             { "$type": "color", "$value": "{color.green.100}" },
  "chart-3-soft-foreground":  { "$type": "color", "$value": "{color.green.800}" },
  "chart-4":                  { "$type": "color", "$value": "{color.orange.600}", "$description": "600 (não 500): ≥3:1 vs superfícies no light — 500 media 2.83:1." },
  "chart-4-solid":            { "$type": "color", "$value": "{color.orange.700}" },
  "chart-4-solid-foreground": { "$type": "color", "$value": "{color.white}" },
  "chart-4-soft":             { "$type": "color", "$value": "{color.orange.100}" },
  "chart-4-soft-foreground":  { "$type": "color", "$value": "{color.orange.800}" },
  "chart-5":                  { "$type": "color", "$value": "{color.red.500}" },
  "chart-5-solid":            { "$type": "color", "$value": "{color.red.600}" },
  "chart-5-solid-foreground": { "$type": "color", "$value": "{color.white}" },
  "chart-5-soft":             { "$type": "color", "$value": "{color.red.100}" },
  "chart-5-soft-foreground":  { "$type": "color", "$value": "{color.red.800}" },
  "chart-6":                  { "$type": "color", "$value": "{color.teal.600}", "$description": "600 (não 500): ≥3:1 vs superfícies no light — 500 media 2.47:1." },
  "chart-6-solid":            { "$type": "color", "$value": "{color.teal.700}" },
  "chart-6-solid-foreground": { "$type": "color", "$value": "{color.white}" },
  "chart-6-soft":             { "$type": "color", "$value": "{color.teal.100}" },
  "chart-6-soft-foreground":  { "$type": "color", "$value": "{color.teal.800}" },
  "chart-7":                  { "$type": "color", "$value": "{color.pink.500}" },
  "chart-7-solid":            { "$type": "color", "$value": "{color.pink.600}" },
  "chart-7-solid-foreground": { "$type": "color", "$value": "{color.white}" },
  "chart-7-soft":             { "$type": "color", "$value": "{color.pink.100}" },
  "chart-7-soft-foreground":  { "$type": "color", "$value": "{color.pink.800}" },
  "chart-8":                  { "$type": "color", "$value": "{color.amber.600}", "$description": "600 (não 500): ≥3:1 vs superfícies no light — 500 media 2.16:1." },
  "chart-8-solid":            { "$type": "color", "$value": "{color.amber.700}" },
  "chart-8-solid-foreground": { "$type": "color", "$value": "{color.white}" },
  "chart-8-soft":             { "$type": "color", "$value": "{color.amber.100}" },
  "chart-8-soft-foreground":  { "$type": "color", "$value": "{color.amber.800}" },
  "chart-9":                  { "$type": "color", "$value": "{color.cyan.600}", "$description": "600 (não 500): ≥3:1 vs superfícies no light — 500 media 2.41:1." },
  "chart-9-solid":            { "$type": "color", "$value": "{color.cyan.700}" },
  "chart-9-solid-foreground": { "$type": "color", "$value": "{color.white}" },
  "chart-9-soft":             { "$type": "color", "$value": "{color.cyan.100}" },
  "chart-9-soft-foreground":  { "$type": "color", "$value": "{color.cyan.800}" },
  "chart-10":                 { "$type": "color", "$value": "{color.fuchsia.500}" },
  "chart-10-solid":           { "$type": "color", "$value": "{color.fuchsia.600}" },
  "chart-10-solid-foreground":{ "$type": "color", "$value": "{color.white}" },
  "chart-10-soft":            { "$type": "color", "$value": "{color.fuchsia.100}" },
  "chart-10-soft-foreground": { "$type": "color", "$value": "{color.fuchsia.800}" },
  "chart-11":                 { "$type": "color", "$value": "{color.lime.600}", "$description": "600 (não 500): ≥3:1 vs superfícies no light — 500 media 1.96:1." },
  "chart-11-solid":           { "$type": "color", "$value": "{color.lime.700}" },
  "chart-11-solid-foreground":{ "$type": "color", "$value": "{color.white}" },
  "chart-11-soft":            { "$type": "color", "$value": "{color.lime.100}" },
  "chart-11-soft-foreground": { "$type": "color", "$value": "{color.lime.800}" },
  "chart-12":                 { "$type": "color", "$value": "{color.indigo.500}" },
  "chart-12-solid":           { "$type": "color", "$value": "{color.indigo.600}" },
  "chart-12-solid-foreground":{ "$type": "color", "$value": "{color.white}" },
  "chart-12-soft":            { "$type": "color", "$value": "{color.indigo.100}" },
  "chart-12-soft-foreground": { "$type": "color", "$value": "{color.indigo.800}" },
  "border":                { "$type": "color", "$value": "{color.neutral.200}" },
  "input":                 { "$type": "color", "$value": "{color.neutral.200}" },
  "sidebar":               { "$type": "color", "$value": "{color.neutral.50}" },
  "sidebar-foreground":    { "$type": "color", "$value": "{color.neutral.900}" },
  "sidebar-accent":        { "$type": "color", "$value": "{color.neutral.100}" },
  "sidebar-accent-foreground": { "$type": "color", "$value": "{color.neutral.900}" },
  "sidebar-border":        { "$type": "color", "$value": "{color.neutral.200}" },

  "link":                  { "$type": "color", "$value": "{primary}", "$description": "Cor de link/texto interativo. Light = primary (legível em superfície clara)." },

  "primary-text":          { "$type": "color", "$value": "{primary}", "$description": "Acento PRIMARY usado como TEXTO/ícone nas variantes não-sólidas (outline/ghost/soft/link). Light = primary (shade 700, AA sobre branco e sobre a tinta soft). Padrão mode-aware análogo a link." },
  "secondary-text":        { "$type": "color", "$value": "{secondary}", "$description": "Acento SECONDARY (roxo) como TEXTO/ícone nas variantes não-sólidas. Light = secondary (shade 700, AA sobre branco e soft). Espelha primary-text — antes a intent-secondary reusava secondary-foreground (era cinza)." },
  "destructive-text":      { "$type": "color", "$value": "{color.red.700}", "$description": "Acento DESTRUCTIVE como TEXTO nas variantes não-sólidas. red.700 p/ passar AA sobre branco E sobre a tinta soft (red.600 reprovava na soft)." },
  "warning-text":          { "$type": "color", "$value": "{color.amber.800}", "$description": "Acento WARNING como TEXTO nas variantes não-sólidas. amber é muito claro: precisa shade 800 p/ AA sobre branco e soft (o warning sólido continua amber.500)." },
  "success-text":          { "$type": "color", "$value": "{color.green.800}", "$description": "Acento SUCCESS como TEXTO nas variantes não-sólidas. green.800 p/ AA sobre branco e sobre a tinta soft (green.700 reprovava na soft)." },
  "info-text":             { "$type": "color", "$value": "{color.sky.700}", "$description": "Acento INFO como TEXTO nas variantes não-sólidas. sky.700 (AA sobre branco e soft)." },

  "surface-ring": { "$type": "color", "$value": "#080a0f0a", "$description": "Fio hairline de 1px (ring-1) em superfícies elevadas (card, popover, menu flutuante). DECORATIVO: separa a superfície do fundo só visualmente — NÃO é um contorno funcional, então NÃO se aplica o mínimo 3:1 não-textual (WCAG 1.4.11); fica de propósito abaixo do limiar (~4% no light). Cor = neutral.950 (cinza azulado #080a0f) a 4% — casa com a paleta neutra, não preto puro. Espelhado no dark (near-white a 10%). Brand-agnóstico." },

  "elevation": {
    "$type": "boxShadow",
    "xs": { "$value": "{shadow.xs}" },
    "sm": { "$value": "{shadow.sm}" },
    "md": { "$value": "{shadow.md}" },
    "lg": { "$value": "{shadow.lg}" },
    "xl": { "$value": "{shadow.xl}" }
  },

  "elevation-panel-l": { "$type": "boxShadow", "$value": "6px 0 24px -18px rgb(8 10 15 / 0.45)", "$description": "Elevação DIRECIONAL de painel vertical ancorado à ESQUERDA (sidebar) — projeta a sombra para a DIREITA (offset-x positivo). Spread negativo (-18px) mantém o halo só na borda direita, sem vazar em cima/baixo. Constante (não varia por marca); o near-black a 45% lê bem em light e dark (no dark o painel é mais claro/colorido que o fundo, então a sombra ainda separa). Par com elevation-panel-r." },
  "elevation-panel-r": { "$type": "boxShadow", "$value": "-16px 0 40px -24px rgb(8 10 15 / 0.25)", "$description": "Elevação DIRECIONAL de painel vertical ancorado à DIREITA (trilho do copiloto) — projeta a sombra para a ESQUERDA (offset-x negativo). Spread negativo (-24px) confina o halo à borda esquerda. Constante (não varia por marca); near-black a 25%. Par com elevation-panel-l." }
}
