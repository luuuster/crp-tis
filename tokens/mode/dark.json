  "link":                       { "$type": "color", "$value": "{brand-primary-on-dark-text}", "$description": "Link/texto interativo no dark — shade 400 (AA como TEXTO em fundo escuro; o primary 600 reprovava)." },

  "primary-text":               { "$type": "color", "$value": "{brand-primary-on-dark-text}", "$description": "Acento PRIMARY como TEXTO nas variantes não-sólidas no dark — shade 400 (AA sobre card/background escuros e sobre a tinta soft; o primary 600 reprovava ~3.4)." },
  "secondary-text":             { "$type": "color", "$value": "{brand-secondary-on-dark-text}", "$description": "Acento SECONDARY (roxo) como TEXTO nas variantes não-sólidas no dark — shade 400 (AA sobre escuro e soft). Espelha primary-text." },
  "destructive-text":           { "$type": "color", "$value": "{color.red.400}", "$description": "Acento DESTRUCTIVE como TEXTO no dark — red.400 (AA sobre superfície escura e soft; red.600 reprovava)." },
  "warning-text":               { "$type": "color", "$value": "{color.amber.600}", "$description": "Acento WARNING como TEXTO no dark — amber.600 (AA sobre escuro e soft). O warning sólido no dark usa amber.400." },
  "success-text":               { "$type": "color", "$value": "{color.green.600}", "$description": "Acento SUCCESS como TEXTO no dark — green.600 (AA sobre escuro e soft; green.700 reprovava)." },
  "info-text":                  { "$type": "color", "$value": "{color.sky.400}", "$description": "Acento INFO como TEXTO no dark — sky.400 (AA sobre escuro e soft; sky.700 reprovava ~3.0)." },
