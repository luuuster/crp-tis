  "info-foreground":       { "$type": "color", "$value": "{color.white}" },

  "primary":                    { "$type": "color", "$value": "{brand-primary-on-dark}", "$description": "Override dark: brand primary no shade 600 — mais visível no fundo escuro que o 700, com TEXTO BRANCO em AA." },
  "primary-foreground":         { "$type": "color", "$value": "{color.white}", "$description": "Texto BRANCO sobre o primary (AA)." },
