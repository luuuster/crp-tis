  "surface-ring": { "$type": "color", "$value": "#ffffff1a", "$description": "Fio hairline de 1px (ring-1) em superfícies elevadas no dark. DECORATIVO (espelha o light): NÃO é contorno funcional, então NÃO se aplica o mínimo 3:1 não-textual (WCAG 1.4.11). near-white a 10% (no escuro o highlight branco lê melhor que um cinza escuro; mesmo papel do ring-white/10 chumbado hoje). Brand-agnóstico." },

  "elevation": {
    "$type": "boxShadow",
    "xs": { "$value": "{shadow.sm}" },
    "sm": { "$value": "{shadow.md}" },
    "md": { "$value": "{shadow.lg}" },
    "lg": { "$value": "{shadow.xl}" },
    "xl": { "$value": "{shadow.2xl}" }
  },

  "elevation-panel-l": { "$type": "boxShadow", "$value": "6px 0 24px -18px rgb(0 0 0 / 0.60)", "$description": "Elevação DIRECIONAL de painel à ESQUERDA no dark — mesma geometria do light (offset-x +6px, projeta p/ direita, spread -18px) com alpha MAIOR (60% vs 45%): a sombra precisa de mais força p/ separar do fundo escuro, espelhando como a escala elevation sobe um passo no dark. Black puro (no dark a sombra é sobre superfície escura)." },
  "elevation-panel-r": { "$type": "boxShadow", "$value": "-16px 0 40px -24px rgb(0 0 0 / 0.45)", "$description": "Elevação DIRECIONAL de painel à DIREITA no dark — mesma geometria do light (offset-x -16px, projeta p/ esquerda, spread -24px) com alpha MAIOR (45% vs 25%) p/ ler sobre o fundo escuro. Black puro." }
