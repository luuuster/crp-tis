  "destructive":           { "$type": "color", "$value": "{color.red.600}", "$description": "red.600 (não 500) p/ o texto BRANCO passar AA no dark (4.71)." },
  "destructive-foreground":{ "$type": "color", "$value": "{color.neutral.50}" },
  "warning":               { "$type": "color", "$value": "{color.amber.400}" },
