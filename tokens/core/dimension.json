{
  "space": {
    "$type": "dimension",
    "0":  { "$value": "0px" },
    "1":  { "$value": "4px" },
    "2":  { "$value": "8px" },
    "3":  { "$value": "12px" },
    "4":  { "$value": "16px" },
    "5":  { "$value": "20px" },
    "6":  { "$value": "24px" },
    "8":  { "$value": "32px" },
    "10": { "$value": "40px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" }
  },
  "radii": {
    "$type": "dimension",
    "none": { "$value": "0px" },
    "sm":   { "$value": "0.375rem" },
    "base": { "$value": "0.625rem" },
    "lg":   { "$value": "0.75rem" },
    "full": { "$value": "9999px" }
  }
}
