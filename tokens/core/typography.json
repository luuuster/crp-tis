{
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": { "$value": "Inter, ui-sans-serif, system-ui, -apple-system, sans-serif" },
      "mono": { "$value": "ui-monospace, SFMono-Regular, Menlo, monospace" }
    },
    "weight": {
      "$type": "fontWeight",
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    },
    "size": {
      "$type": "dimension",
      "xs":  { "$value": "0.75rem" },
      "sm":  { "$value": "0.875rem" },
      "base":{ "$value": "1rem" },
      "lg":  { "$value": "1.125rem" },
      "xl":  { "$value": "1.25rem" },
      "2xl": { "$value": "1.5rem" }
    }
  }
}
