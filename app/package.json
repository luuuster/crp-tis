    "input-otp": "^1.4.2",
    "lucide-react": "^1.18.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "^19.0.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.0",
